{{#unless skip_basic_meta}}
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{title}}</title>
{{/unless}}
<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
<meta http-equiv="Pragma" content="no-cache" />
<meta http-equiv="Expires" content="0" />

<link rel="preconnect" href="https://api.web3forms.com" crossorigin>
<link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>
<link rel="preconnect" href="https://www.google-analytics.com" crossorigin>
<meta name="referrer" content="strict-origin-when-cross-origin">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<meta name="description" content="{{description}}" />
<meta name="keywords" content="{{keywords}}" />
  <meta name="author" content="DigiKaveri" />
  <meta name="theme-color" content="#2563EB" />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://digikaveri.com/{{path}}" />
  <meta property="og:title" content="{{title}}" />
  <meta property="og:description" content="{{description}}" />
  <meta property="og:image" content="https://digikaveri.com/images/og-preview.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="DigiKaveri" />
  <meta property="og:locale" content="{{og_locale}}" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content="https://digikaveri.com/{{path}}" />
  <meta property="twitter:title" content="{{title}}" />
  <meta property="twitter:description" content="{{description}}" />
  <meta property="twitter:image" content="https://digikaveri.com/images/og-preview.png" />

<link rel="canonical" href="https://digikaveri.com/{{#if_eq lang 'fi'}}{{#if_eq path 'index.html'}}{{else}}{{path}}{{/if_eq}}{{else}}en/{{#if_eq path 'en/index.html'}}{{else}}{{en_path}}{{/if_eq}}{{/if_eq}}" />
<link rel="alternate" hreflang="fi" href="https://digikaveri.com/{{#if_eq fi_path 'index.html'}}{{else}}{{fi_path}}{{/if_eq}}" />
<link rel="alternate" hreflang="en" href="https://digikaveri.com/en/{{#if_eq en_path 'index.html'}}{{else}}{{en_path}}{{/if_eq}}" />
<link rel="alternate" hreflang="x-default" href="https://digikaveri.com/{{#if_eq fi_path 'index.html'}}{{else}}{{fi_path}}{{/if_eq}}" />

<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="shortcut icon" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-title" content="DigiKaveri" />
<link rel="manifest" href="/site.webmanifest" />

<link rel="stylesheet" href="/css/variables.css" />
<link rel="stylesheet" href="/css/global.css" />
{{#if extra_css}}
<link rel="stylesheet" href="/css/{{extra_css}}.css" />
{{/if}}
<noscript>
  <style>
    .quiz-step {
      display: block !important;
      opacity: 1 !important;
      transform: none !important;
      margin-bottom: 30px;
    }
    .btn-quiz-nav.prev {
      display: none !important;
    }
  </style>
</noscript>
<!-- Non-blocking CSS: loads after initial render -->
<link rel="preload" href="https://unpkg.com/aos@2.3.1/dist/aos.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
<noscript><link rel="stylesheet" href="https://unpkg.com/aos@2.3.1/dist/aos.css" /></noscript>
<link rel="preload" href="https://cdn.jsdelivr.net/gh/orestbida/cookieconsent@3.1.0/dist/cookieconsent.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
<noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orestbida/cookieconsent@3.1.0/dist/cookieconsent.css" /></noscript>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ComputerStore",
  "name": "DigiKaveri",
  "url": "https://digikaveri.com/",
  "logo": "https://digikaveri.com/images/logo.webp",
  "description": "Everyday IT Help & Computer Repair in Uusimaa and remotely across Finland.",
  "telephone": "+3584578338105",
  "areaServed": {
    "@type": "AdministrativeArea",
    "name": "Uusimaa"
  },
  "address": {
    "@type": "PostalAddress",
    "addressRegion": "Uusimaa",
    "addressCountry": "FI"
  },
  "priceRange": "€€",
  "openingHours": "Mo,Tu,We,Th,Fr,Sa,Su 09:00-21:00"
}
</script>
