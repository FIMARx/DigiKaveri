<footer class="modern-footer">
  <div class="footer-container">
    <div class="footer-brand">
      <div class="logo footer-logo">
        <img
          src="{{base}}images/logo.png"
          alt="DigiKaveri Logo"
          loading="lazy"
          width="350"
          height="auto"
        />
      </div>
      <p class="footer-desc">
        {{footer_desc}}
      </p>
      <div class="footer-social">
        <a href="https://facebook.com" target="_blank" aria-label="Facebook">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-facebook" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://instagram.com" target="_blank" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-instagram" aria-hidden="true"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        </a>
      </div>
    </div>

    <div class="footer-links">
      <h3>{{footer_links_title}}</h3>
      <ul>
        <li><a href="index.html#home">{{nav_home}}</a></li>
        <li><a href="{{etätuki_url}}">{{nav_remote}}</a></li>
        <li><a href="index.html#solutions">{{nav_services}}</a></li>
        <li><a href="index.html#pricing">{{nav_pricing}}</a></li>
        <li><a href="index.html#team">{{nav_team}}</a></li>
        <li><a href="index.html#faq">FAQ</a></li>
        <li><a href="{{privacy_url}}">{{nav_privacy}}</a></li>
        <li><a href="{{terms_url}}">{{nav_terms}}</a></li>
      </ul>
    </div>

    <div class="footer-contact">
      <h3>{{footer_contact_title}}</h3>
      <ul>
        <li>
          <i data-lucide="phone" aria-hidden="true"></i>
          <a href="tel:+3584578338105">045 7833 8105</a>
        </li>
        <li>
          <i data-lucide="mail" aria-hidden="true"></i>
          <a href="mailto:info@digikaveri.com">info@digikaveri.com</a>
        </li>
        <li>
          <i data-lucide="map-pin" aria-hidden="true"></i>
          <a href="https://maps.app.goo.gl/ZMahtgeVwC3wE3wXA" target="_blank" rel="noopener noreferrer">{{footer_location}}</a>
        </li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; 2026 DigiKaveri. {{footer_rights}}</p>
  </div>
</footer>

