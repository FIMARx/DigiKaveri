<!-- Service Closed Modal -->
<div id="statusModal" class="status-modal-overlay" tabindex="-1">
  <div class="status-modal-card">
    <div class="status-modal-icon">
      <i data-lucide="clock"></i>
    </div>
    <h2 id="modalTitle">{{modal_closed_title}}</h2>
    <p id="modalDescription">
      {{modal_closed_desc}}
    </p>
    <div class="status-modal-actions">
      <button id="modalCallback" class="btn-modal-primary">
        <i data-lucide="phone-call"></i> {{modal_call_btn}}
      </button>
      <button id="modalUnderstand" class="btn-modal-secondary">
        {{modal_ok_btn}}
      </button>
    </div>
  </div>
</div>
